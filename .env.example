# Kopiere diese Datei nach ".env" und passe die Werte an:
#   cp .env.example .env

# --- Pflicht für HTTPS ---
# Deine Domain/Subdomain, die per DNS A-Record auf die Server-IP zeigt.
DOMAIN=theo.example.de
# E-Mail für Let's Encrypt (Zertifikats-Benachrichtigungen).
ACME_EMAIL=du@example.de

# --- Optional ---
# Claude-RAG-Backend aktivieren (bessere Antworten). Leer lassen = lokale Wissensbasis.
ANTHROPIC_API_KEY=

# Genauerer Detektor (YOLO) – beim Build aktivieren. Braucht mehr RAM/Disk.
INSTALL_YOLO=false
# Standard-Detektor der Weboberfläche: hog oder yolo.
THEO_DEFAULT_DETECTOR=hog

# Performance / Limits
THEO_WORKERS=2
THEO_MAX_ANALYZE_SECONDS=30
THEO_MAX_UPLOAD_MB=200
